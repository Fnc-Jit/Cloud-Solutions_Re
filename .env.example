# ============================================================
# CloudFinOps-Env — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Run:  python inference.py
#
# That's it. Everything reads from this file automatically.
# ============================================================

# The API endpoint for the LLM (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1

# The model identifier to use for inference
MODEL_NAME=gpt-4o

# Your API key
HF_TOKEN=your_api_key_here
